<%
  const title = `Contact Us | Wildlife Removal Help in ${county ? county + ', ' + state : 'Your Area'} | RemoveWildlifeNow.com`;
  const metaDesc = 'No local contractor in your area yet? Contact us and we will connect you with a wildlife removal professional as soon as possible.';
  const canonical = '/contact/';
%>
<%- include('layout', { title, metaDesc, canonical, body: `

<section class="page-hero">
  <div class="container">
    <div class="hero-badge">We Can Help</div>
    <h1>Contact Us for Help</h1>
    <p>No contractor in your area yet — send us your info and we'll connect you with a professional as soon as possible.</p>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <div class="cta-box" style="max-width:580px;">

      ${sent ? `
      <div class="success-msg">
        <span style="font-size:2.5rem;">✅</span>
        <h2>Message Sent!</h2>
        <p>We received your request and will be in touch shortly to connect you with a local wildlife removal professional.</p>
        <a href="/" class="btn-primary" style="margin-top:20px;display:inline-block;">Back to Home</a>
      </div>
      ` : `
      <h2>Get Wildlife Removal Help</h2>
      <p class="cta-sub">Fill out the form below and we'll find a licensed contractor in your area.</p>

      ${error ? \`<p class="form-error">\${error}</p>\` : ''}

      <form class="contact-form" method="POST" action="/contact/">
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" required placeholder="John Smith" value="${formData.name || ''}">
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" value="${formData.email || ''}">
        </div>
        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 555-5555" value="${formData.phone || ''}">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="county">County</label>
            <input type="text" id="county" name="county" placeholder="e.g. Cobb County" value="${formData.county || county || ''}">
          </div>
          <div class="form-group">
            <label for="state">State</label>
            <input type="text" id="state" name="state" placeholder="e.g. Georgia" value="${formData.state || state || ''}">
          </div>
        </div>
        <div class="form-group">
          <label for="animal">What animal do you have?</label>
          <select id="animal" name="animal">
            <option value="" ${!formData.animal ? 'selected' : ''}>Select animal...</option>
            <option ${formData.animal === 'Raccoon' ? 'selected' : ''}>Raccoon</option>
            <option ${formData.animal === 'Squirrel' ? 'selected' : ''}>Squirrel</option>
            <option ${formData.animal === 'Bat' ? 'selected' : ''}>Bat</option>
            <option ${formData.animal === 'Snake' ? 'selected' : ''}>Snake</option>
            <option ${formData.animal === 'Groundhog / Mole' ? 'selected' : ''}>Groundhog / Mole</option>
            <option ${formData.animal === 'Bird' ? 'selected' : ''}>Bird</option>
            <option ${formData.animal === 'Other' ? 'selected' : ''}>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Describe the issue</label>
          <textarea id="message" name="message" rows="4" placeholder="Where is the animal? Attic, crawlspace, yard? Any damage?">${formData.message || ''}</textarea>
        </div>
        <button type="submit" class="btn-submit">Send My Request</button>
      </form>
      `}

    </div>
  </div>
</section>

` }) %>
