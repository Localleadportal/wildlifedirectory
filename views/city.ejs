<%
  const pageUrl = 'https://www.removewildlifenow.com/' + stateSlug + '/' + countySlug + '/' + citySlug + '/';
  const pageTitle = (cityContent && cityContent.metaTitle)
    ? cityContent.metaTitle
    : (cityContent
        ? ('Wildlife Removal in ' + cityName + ', ' + stateName + ' — Licensed Local Contractors')
        : ('Wildlife Removal in ' + cityName + ', ' + stateName + ' | RemoveWildlifeNow.com'));
  const pageDesc = (cityContent && cityContent.metaDescription)
    ? cityContent.metaDescription
    : (cityContent
        ? ('Licensed wildlife removal in ' + cityName + ', ' + stateName + '. Raccoons, squirrels, bats, snakes, armadillos and more. Same-day service from local ' + countyName + ' contractors.')
        : ('Find a licensed wildlife removal contractor in ' + cityName + ', ' + stateName + '. Local experts serving ' + cityName + ' for raccoon, squirrel, bat, snake removal and more.'));
  const ogImage = (cityContent && cityContent.ogImage)
    ? cityContent.ogImage
    : 'https://www.removewildlifenow.com/images/hero1.jpg';
  const seoEnhanced = !!(cityContent && cityContent.geo);
  const stateRegion = stateName === 'Georgia' ? 'GA'
    : stateName === 'Tennessee' ? 'TN'
    : stateName === 'Delaware' ? 'DE'
    : stateName === 'Connecticut' ? 'CT'
    : stateName === 'New Hampshire' ? 'NH'
    : stateName === 'Vermont' ? 'VT'
    : stateName === 'Rhode Island' ? 'RI' : '';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDesc %>">
  <link rel="canonical" href="<%= pageUrl %>">
  <link rel="stylesheet" href="/css/style.css">
  <% if (!indexable) { %>
  <meta name="robots" content="noindex, follow">
  <% } else if (seoEnhanced) { %>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">
  <% } %>

  <% if (seoEnhanced) { %>
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="RemoveWildlifeNow.com">
  <meta property="og:locale" content="en_US">
  <meta property="og:url" content="<%= pageUrl %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:image" content="<%= ogImage %>">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDesc %>">
  <meta name="twitter:image" content="<%= ogImage %>">

  <!-- Geo -->
  <meta name="geo.region" content="US-<%= stateRegion %>">
  <meta name="geo.placename" content="<%= cityName %>, <%= stateName %>">
  <meta name="geo.position" content="<%= cityContent.geo.lat %>;<%= cityContent.geo.lon %>">
  <meta name="ICBM" content="<%= cityContent.geo.lat %>, <%= cityContent.geo.lon %>">

  <!-- BreadcrumbList -->
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": pageUrl + "#breadcrumb",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.removewildlifenow.com/" },
      { "@type": "ListItem", "position": 2, "name": stateName, "item": "https://www.removewildlifenow.com/" + stateSlug + "/" },
      { "@type": "ListItem", "position": 3, "name": countyName, "item": "https://www.removewildlifenow.com/" + stateSlug + "/" + countySlug + "/" },
      { "@type": "ListItem", "position": 4, "name": cityName }
    ]
  }) %>
  </script>

  <!-- WebPage -->
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": pageUrl + "#webpage",
    "url": pageUrl,
    "name": pageTitle,
    "description": pageDesc,
    "isPartOf": { "@id": "https://www.removewildlifenow.com/#website" },
    "breadcrumb": { "@id": pageUrl + "#breadcrumb" },
    "inLanguage": "en-US",
    "about": { "@id": pageUrl + "#business" },
    "primaryImageOfPage": ogImage
  }) %>
  </script>

  <!-- Place -->
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Place",
    "@id": pageUrl + "#place",
    "name": cityName + ", " + stateName,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": cityName,
      "addressRegion": stateRegion,
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": cityContent.geo.lat,
      "longitude": cityContent.geo.lon
    },
    ...(cityContent.sameAs && cityContent.sameAs.length ? { "sameAs": cityContent.sameAs } : {})
  }) %>
  </script>
  <% } %>

  <!-- LocalBusiness / ProfessionalService -->
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    ...(seoEnhanced ? { "@id": pageUrl + "#business" } : {}),
    "name": "Wildlife Removal in " + cityName,
    "description": pageDesc,
    "url": pageUrl,
    "telephone": "+1-844-544-3498",
    "priceRange": "$$",
    ...(seoEnhanced ? {
      "address": {
        "@type": "PostalAddress",
        "addressLocality": cityName,
        "addressRegion": stateRegion,
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": cityContent.geo.lat,
        "longitude": cityContent.geo.lon
      }
    } : {}),
    "areaServed": [
      { "@type": "City", "name": cityName + ", " + stateName },
      { "@type": "AdministrativeArea", "name": countyName + ", " + stateName }
    ],
    "serviceType": "Wildlife Removal",
    "openingHours": "Mo-Su 00:00-23:59",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Wildlife Removal Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Raccoon Removal" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Squirrel Removal" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bat Removal & Exclusion" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Snake Removal" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Opossum Removal" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Skunk Removal" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Armadillo Removal" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Coyote Control" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Attic Decontamination & Remediation" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Animal Exclusion & Entry-Point Sealing" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Dead Animal Removal" } }
      ]
    }
  }) %>
  </script>

  <% if (cityContent && cityContent.faqs && cityContent.faqs.length) { %>
  <!-- FAQPage -->
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    ...(seoEnhanced ? { "@id": pageUrl + "#faq" } : {}),
    "mainEntity": cityContent.faqs.map(function(f){
      return { "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } };
    })
  }) %>
  </script>
  <% } %>
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="/" class="logo">RemoveWildlife<span>Now</span></a>
      <nav class="header-nav">
        <a href="/">Home</a>
        <a href="/<%= stateSlug %>/"><%= stateName %></a>
        <a href="/<%= stateSlug %>/<%= countySlug %>/"><%= countyName %></a>
      </nav>
      <a class="llp-phone header-phone" href="tel:+18445443498">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (844) 544-3498
      </a>
    </div>
  </header>

  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="trust-item">24/7 Emergency Response</div>
      <div class="trust-item">Licensed &amp; Insured</div>
      <div class="trust-item">Humane Methods</div>
      <div class="trust-item">Local Experts</div>
    </div>
  </div>

  <main>
    <nav class="breadcrumb">
      <div class="container">
        <a href="/">Home</a> &rsaquo; <a href="/<%= stateSlug %>/"><%= stateName %></a> &rsaquo; <a href="/<%= stateSlug %>/<%= countySlug %>/"><%= countyName %></a> &rsaquo; <span><%= cityName %></span>
      </div>
    </nav>

    <section class="page-hero">
      <div class="container">
        <div class="hero-badge">Serving <%= cityName %>, <%= stateName %></div>
        <h1>Wildlife Removal in <%= cityName %></h1>
        <p>Local licensed experts serving <%= cityName %> and surrounding areas in <%= countyName %>.</p>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <h2>Your <%= cityName %> Wildlife Removal Expert</h2>
          <p class="llp-company-name company-name" style="display:none;"></p>
          <p class="cta-sub">Licensed, insured &amp; local. Same-day and emergency service available in <%= cityName %>.</p>
          <div class="phone-wrap">
            <a class="llp-phone phone-cta" href="tel:+18445443498">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (844) 544-3498
            </a>
          </div>
          <p class="cta-note llp-available-only">Serving <%= cityName %> and all of <%= countyName %>, <%= stateName %></p>
          <% if (!indexable) { %>
          <div class="no-contractor-section" id="no-contractor">
            <h3><a href="tel:+18445443498" style="color:inherit;text-decoration:none;">(844) 544-3498</a></h3>
            <p>We're expanding fast. Contact us and we'll connect you with help in <%= cityName %>.</p>
            <a href="/contact/?county=<%= encodeURIComponent(countyName) %>&state=<%= encodeURIComponent(stateName) %>" class="btn-contact">Contact Us for Help</a>
          </div>
          <% } %>
          <div class="cta-badges">
            <span class="cta-badge"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Licensed &amp; Insured</span>
            <span class="cta-badge"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Same-Day Available</span>
            <span class="cta-badge"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> Humane Methods</span>
          </div>
        </div>
      </div>
    </section>

    <section class="services-section">
      <div class="container">
        <h2>Wildlife Removal Services in <%= cityName %></h2>
        <p class="section-sub">Our <%= countyName %> contractor serves all of <%= cityName %> — the same licensed professional handles every job in your area.</p>
        <ul class="counties-grid">
          <% ANIMALS.forEach(a => { %>
          <li><a href="/<%= stateSlug %>/<%= countySlug %>/<%= citySlug %>/<%= a.slug %>/"><%= a.emoji %> <%= a.name %></a></li>
          <% }); %>
        </ul>
      </div>
    </section>

    <section class="county-content">
      <div class="container">
        <h2>Wildlife Problems in <%= cityName %>, <%= stateName %></h2>
        <% if (cityContent && cityContent.wildlife_intro) { %>
        <% if (cityContent.wildlife_intro.trim().charAt(0) === '<') { %>
        <%- cityContent.wildlife_intro %>
        <% } else { %>
        <p><%- cityContent.wildlife_intro %></p>
        <% } %>
        <% if (stateInfo) { %>
        <p>The contractor serving <%= cityName %> is licensed by the <strong><%= stateInfo.agency %></strong> and knows the specific wildlife patterns, local regulations, and most effective removal methods for your area.</p>
        <% } %>
        <% } else if (stateInfo) { %>
        <p><%= stateInfo.wildlifeNote %></p>
        <p>The contractor serving <%= cityName %> is licensed by the <strong><%= stateInfo.agency %></strong> and knows the specific wildlife patterns, local regulations, and most effective removal methods for your area. <%= stateInfo.seasonNote %></p>
        <% } else { %>
        <p>Homeowners in <%= cityName %> deal with many of the same wildlife issues found throughout <%= countyName %>. Raccoons, squirrels, bats, and snakes are among the most common — often entering through damaged soffits, vents, and rooflines in residential neighborhoods.</p>
        <p>The contractor serving <%= cityName %> is based in <%= countyName %> and knows the specific wildlife patterns, local regulations, and most effective removal methods for your area.</p>
        <% } %>

        <% if (cityContent && cityContent.neighborhoods && cityContent.neighborhoods.length) { %>
        <h3><%= cityName %> Neighborhoods We Serve</h3>
        <p>The local contractor handles wildlife removal calls across every neighborhood and corridor in <%= cityName %>, including:</p>
        <ul class="tips-list">
          <% cityContent.neighborhoods.forEach(function(n) { %>
          <li><%= n %></li>
          <% }); %>
        </ul>
        <% } %>

        <% if (cityContent && cityContent.geographic_features && cityContent.geographic_features.length) { %>
        <h3>Local Geography Driving Wildlife Pressure</h3>
        <p><%= cityName %>'s wildlife corridors and natural features include:</p>
        <ul class="tips-list">
          <% cityContent.geographic_features.forEach(function(g) { %>
          <li><%= g %></li>
          <% }); %>
        </ul>
        <% } %>

        <h3>Why Use a Local <%= cityName %> Contractor?</h3>
        <ul class="tips-list">
          <li>They know the wildlife species most common to <%= cityName %> neighborhoods</li>
          <li>Familiar with local ordinances and <%= stateName %> wildlife removal regulations</li>
          <li>Faster response time — they're already in your area</li>
          <li>Follow-up visits are easy when the contractor is local</li>
        </ul>
      </div>
    </section>

    <% if (cityContent && cityContent.faqs && cityContent.faqs.length) { %>
    <section class="faq-section">
      <div class="container">
        <h2><%= cityName %> Wildlife Removal FAQ</h2>
        <% cityContent.faqs.forEach(function(faq) { %>
        <details class="faq-item">
          <summary><%= faq.q %></summary>
          <p><%- faq.a %></p>
        </details>
        <% }); %>
      </div>
    </section>
    <% } %>
  </main>

  <footer>
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> RemoveWildlifeNow.com &mdash; Connecting homeowners with licensed wildlife removal professionals nationwide.</p>
    </div>
  </footer>

  <script src="<%- embedScript %>"></script>
</body>
</html>
