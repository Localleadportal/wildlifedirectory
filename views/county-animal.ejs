<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= animal.name %> in <%= countyName %>, <%= stateName %> — Licensed Local Experts | RemoveWildlifeNow.com</title>
  <meta name="description" content="<%= animal.name %> in <%= countyName %>, <%= stateName %>. <%= animal.costRange ? 'Typical cost ' + animal.costRange + '. ' : '' %>Licensed local contractor — humane methods, same-day service available. <%= seasonal ? seasonal.title + '.' : '' %>">
  <link rel="canonical" href="https://www.removewildlifenow.com/<%= stateSlug %>/<%= countySlug %>/<%= animal.slug %>/">
  <link rel="stylesheet" href="/css/style.css">
  <% if (!hasContractor) { %><meta name="robots" content="noindex, follow"><% } %>
  <% if (faqs && faqs.length) { %>
  <script type="application/ld+json">
  <%- JSON.stringify({ "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(function(f){ return { "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }; }) }) %>
  </script>
  <% } %>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "name": animal.name + " in " + countyName,
    "description": animal.shortDesc + " Serving all of " + countyName + ", " + stateName + ".",
    "url": "https://www.removewildlifenow.com/" + stateSlug + "/" + countySlug + "/" + animal.slug + "/",
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": countyName + ", " + stateName
    },
    "serviceType": animal.name,
    "openingHours": "Mo-Su 00:00-23:59",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": animal.name + " Services",
      "itemListElement": animal.services.map(function(svc) {
        return { "@type": "Offer", "itemOffered": { "@type": "Service", "name": svc } };
      })
    }
  }) %>
  </script>
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="/" class="logo">RemoveWildlife<span>Now</span></a>
      <nav class="header-nav">
        <a href="/">Home</a>
        <a href="/<%= stateSlug %>/"><%= stateName %></a>
        <a href="/<%= stateSlug %>/<%= countySlug %>/"><%= countyName %></a>
      </nav>
      <a class="llp-phone header-phone" href="tel:+18445443498">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        (844) 544-3498
      </a>
    </div>
  </header>

  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="trust-item">24/7 Emergency Response</div>
      <div class="trust-item">Licensed &amp; Insured</div>
      <div class="trust-item">Humane Methods</div>
      <div class="trust-item">Local Experts</div>
    </div>
  </div>

  <main>
    <nav class="breadcrumb">
      <div class="container">
        <a href="/">Home</a> &rsaquo; <a href="/<%= stateSlug %>/"><%= stateName %></a> &rsaquo; <a href="/<%= stateSlug %>/<%= countySlug %>/"><%= countyName %></a> &rsaquo; <span><%= animal.name %></span>
      </div>
    </nav>

    <section class="page-hero">
      <div class="container">
        <div class="hero-badge"><%= countyName %>, <%= stateName %></div>
        <h1><%= animal.emoji %> <%= animal.name %> in <%= countyName %></h1>
        <p><%= animal.shortDesc %></p>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <h2><%= animal.name %> — <%= countyName %></h2>
          <p class="llp-company-name company-name" style="display:none;"></p>
          <p class="cta-sub">Licensed local expert. Same-day and emergency service available.</p>
          <div class="phone-wrap">
            <a class="llp-phone phone-cta" href="tel:+18445443498">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (844) 544-3498
            </a>
          </div>
          <p class="cta-note llp-available-only">Serving all of <%= countyName %>, <%= stateName %></p>
          <div class="no-contractor-section" id="no-contractor">
            <h3>No Contractor Assigned Yet</h3>
            <p>We're expanding fast. Contact us and we'll find help for your <%= animal.name.toLowerCase() %> problem.</p>
            <a href="/contact/?county=<%= encodeURIComponent(countyName) %>&state=<%= encodeURIComponent(stateName) %>" class="btn-contact">Contact Us for Help</a>
          </div>
          <div class="cta-badges">
            <span class="cta-badge"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Licensed &amp; Insured</span>
            <span class="cta-badge"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Same-Day Available</span>
            <span class="cta-badge"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> Humane Methods</span>
          </div>
        </div>
      </div>
    </section>

    <section class="services-section">
      <div class="container">
        <h2><%= animal.name %> Services in <%= countyName %></h2>
        <p class="section-sub"><%= animal.urgency %></p>
        <div class="service-cards">
          <div class="service-card featured">
            <span class="card-badge">Signs You Have <%= animal.plural %></span>
            <span class="card-icon"><%= animal.emoji %></span>
            <h3>Warning Signs</h3>
            <p><%= animal.season %></p>
            <ul class="card-list">
              <% animal.signs.forEach(sign => { %>
              <li><%= sign %></li>
              <% }); %>
            </ul>
            <a class="llp-phone card-phone" href="tel:+18445443498">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (844) 544-3498
            </a>
          </div>
          <div class="service-card">
            <span class="card-icon">🛠️</span>
            <h3>Our <%= animal.name %> Process</h3>
            <p>Our <%= countyName %> contractor uses proven, humane methods to remove <%= animal.plural.toLowerCase() %> and keep them from coming back.</p>
            <ul class="card-list">
              <% animal.services.forEach(svc => { %>
              <li><%= svc %></li>
              <% }); %>
            </ul>
            <a class="llp-phone card-phone" href="tel:+18445443498">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (844) 544-3498
            </a>
          </div>
        </div>
      </div>
    </section>

    <% if (cities.length > 0) { %>
    <section class="counties-section">
      <div class="container">
        <div class="section-header">
          <h2><%= animal.name %> by City in <%= countyName %></h2>
          <p>Find <%= animal.name.toLowerCase() %> help in your specific city</p>
        </div>
        <ul class="counties-grid">
          <% cities.forEach(city => { %>
          <li><a href="/<%= stateSlug %>/<%= countySlug %>/<%= toSlug(city) %>/<%= animal.slug %>/"><%= city %></a></li>
          <% }); %>
        </ul>
      </div>
    </section>
    <% } %>

    <% if (seasonal) { %>
    <section class="county-content" style="background:<%= seasonal.level === 'high' ? '#fff7ed' : seasonal.level === 'moderate' ? '#f0fdf4' : '#f8fafc' %>;border-top:3px solid <%= seasonal.level === 'high' ? '#f97316' : seasonal.level === 'moderate' ? '#22c55e' : '#94a3b8' %>;">
      <div class="container">
        <h2 style="color:<%= seasonal.level === 'high' ? '#c2410c' : seasonal.level === 'moderate' ? '#15803d' : '#475569' %>;margin-bottom:8px;">
          <%= seasonal.level === 'high' ? '⚠️' : seasonal.level === 'moderate' ? '📅' : '📋' %> <%= seasonal.title %>
        </h2>
        <p><%= seasonal.msg %></p>
      </div>
    </section>
    <% } %>

    <% if (animalRegionNote || stateInfo) { %>
    <section class="county-content">
      <div class="container">
        <h2><%= animal.name %> in <%= countyName %>, <%= stateName %> — What You Should Know</h2>
        <% if (animalRegionNote) { %>
        <p><%= animalRegionNote %></p>
        <% } %>
        <% if (stateInfo) { %>
        <p>All wildlife removal in <%= stateName %> is regulated by the <strong><%= stateInfo.agency %></strong>. Our <%= countyName %> contractors hold all required state permits and use only legal, humane methods approved by the <%= stateInfo.agency %>.</p>
        <% } %>
      </div>
    </section>
    <% } %>

    <% if (animal.costRange) { %>
    <section class="county-content" style="background:#f8fafc;">
      <div class="container">
        <h2><%= animal.name %> Cost in <%= stateName %></h2>
        <p style="font-size:1.5rem;font-weight:700;color:var(--primary);margin:0 0 8px;"><%= animal.costRange %></p>
        <p style="color:#6b7280;margin:0;"><%= animal.costNote %> Pricing varies by contractor, location, and severity. Call for a free estimate specific to your situation.</p>
      </div>
    </section>
    <% } %>

    <% if (faqs && faqs.length) { %>
    <section class="county-content">
      <div class="container">
        <h2>Frequently Asked Questions — <%= animal.name %> in <%= countyName %></h2>
        <div style="display:flex;flex-direction:column;gap:16px;margin-top:16px;">
          <% faqs.forEach(function(faq) { %>
          <details style="border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;">
            <summary style="padding:16px 20px;font-weight:600;cursor:pointer;font-size:0.97rem;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              <%= faq.q %>
              <span style="font-size:1.2rem;flex-shrink:0;margin-left:12px;">+</span>
            </summary>
            <div style="padding:0 20px 16px;color:#374151;line-height:1.7;font-size:0.93rem;border-top:1px solid #f3f4f6;"><%= faq.a %></div>
          </details>
          <% }); %>
        </div>
      </div>
    </section>
    <% } %>

    <section class="counties-section">
      <div class="container">
        <div class="section-header">
          <h2>More Wildlife Services in <%= countyName %></h2>
          <p>We handle all wildlife removal needs in <%= countyName %></p>
        </div>
        <ul class="counties-grid">
          <% ANIMALS.filter(a => a.slug !== animal.slug).forEach(a => { %>
          <li><a href="/<%= stateSlug %>/<%= countySlug %>/<%= a.slug %>/"><%= a.emoji %> <%= a.name %></a></li>
          <% }); %>
        </ul>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> RemoveWildlifeNow.com &mdash; Connecting homeowners with licensed wildlife removal professionals nationwide.</p>
    </div>
  </footer>

  <script src="<%- embedScript %>"></script>
</body>
</html>
