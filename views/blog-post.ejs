<%
  const pageUrl = 'https://www.removewildlifenow.com/blog/' + post.slug + '/';
  const title = post.metaTitle || post.title;
  const metaDesc = post.metaDescription || post.excerpt;
  const canonical = '/blog/' + post.slug + '/';
  const ogImage = 'https://www.removewildlifenow.com/images/og-default.jpg';

  const graph = [
    {
      "@type": "BreadcrumbList",
      "@id": pageUrl + "#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.removewildlifenow.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.removewildlifenow.com/blog/" },
        { "@type": "ListItem", "position": 3, "name": post.title }
      ]
    },
    {
      "@type": "Article",
      "@id": pageUrl + "#article",
      "headline": post.title,
      "description": post.excerpt,
      "url": pageUrl,
      "datePublished": post.datePublished,
      "dateModified": post.dateModified,
      "author": { "@type": "Organization", "name": post.author, "url": "https://www.removewildlifenow.com/" },
      "publisher": { "@id": "https://www.removewildlifenow.com/#organization" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
      "image": ogImage,
      "articleSection": post.category,
      "keywords": (post.tags || []).join(', '),
      "inLanguage": "en-US"
    }
  ];

  if (post.faqs && post.faqs.length) {
    graph.push({
      "@type": "FAQPage",
      "@id": pageUrl + "#faq",
      "mainEntity": post.faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    });
  }

  const schema = JSON.stringify({ "@context": "https://schema.org", "@graph": graph });

  const extraHead = `
    <meta property="og:type" content="article">
    <meta property="og:site_name" content="RemoveWildlifeNow.com">
    <meta property="og:url" content="${pageUrl}">
    <meta property="og:title" content="${title}">
    <meta property="og:description" content="${metaDesc}">
    <meta property="og:image" content="${ogImage}">
    <meta property="article:published_time" content="${post.datePublished}">
    <meta property="article:modified_time" content="${post.dateModified}">
    <meta property="article:author" content="${post.author}">
    <meta property="article:section" content="${post.category}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="${title}">
    <meta name="twitter:description" content="${metaDesc}">
    <meta name="twitter:image" content="${ogImage}">
    <meta name="robots" content="index, follow">
  `;

  function formatDate(iso) {
    const d = new Date(iso + 'T00:00:00Z');
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
  }

  const relatedPosts = relatedPostsList || [];
%>
<%- include('layout', { title, metaDesc, canonical, schema, extraHead, body: `

<nav class="breadcrumb">
  <div class="container">
    <a href="/">Home</a> &rsaquo; <a href="/blog/">Blog</a> &rsaquo; <span>${post.title}</span>
  </div>
</nav>

<article style="max-width:780px;margin:0 auto;padding:32px 20px 16px;">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap;">
    <span style="background:var(--green-light);color:var(--green-dark);padding:4px 12px;border-radius:6px;font-size:0.8rem;font-weight:600;">${post.category}</span>
    <span style="color:#6b7280;font-size:0.9rem;">${formatDate(post.datePublished)}</span>
    ${post.dateModified !== post.datePublished ? `<span style="color:#6b7280;font-size:0.85rem;">(Updated ${formatDate(post.dateModified)})</span>` : ''}
  </div>
  <h1 style="font-size:2.1rem;line-height:1.2;margin:0 0 20px;color:#0f172a;">${post.title}</h1>
  <p style="color:#475569;font-size:1.1rem;line-height:1.6;margin:0 0 8px;">${post.excerpt}</p>
  <p style="color:#9ca3af;font-size:0.9rem;margin:0 0 32px;">By ${post.author}</p>
</article>

<article style="max-width:780px;margin:0 auto;padding:0 20px 32px;font-size:1.02rem;line-height:1.75;color:#1f2937;">
  <style>
    article h2 { font-size:1.5rem; margin:36px 0 14px; color:#0f172a; line-height:1.3; }
    article h3 { font-size:1.18rem; margin:28px 0 10px; color:#0f172a; line-height:1.35; }
    article p { margin:0 0 16px; }
    article ul, article ol { margin:0 0 18px; padding-left:24px; }
    article li { margin-bottom:8px; }
    article a { color:var(--primary); text-decoration:underline; }
    article .lead { font-size:1.12rem; color:#1e293b; margin-bottom:24px; }
  </style>
  ${post.body}
</article>

<section class="cta-section">
  <div class="container">
    <div class="cta-box">
      <h2>Get Connected With a Licensed Wildlife Removal Pro</h2>
      <p class="cta-sub">Skip the research — call our 24/7 dispatch line for an immediate connection.</p>
      <div class="phone-wrap">
        <a class="llp-phone phone-cta" href="tel:+18445443498">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          (844) 544-3498
        </a>
      </div>
      <p class="cta-note">Or <a href="/" style="color:var(--primary);font-weight:600;">find a contractor by state</a>.</p>
      <div class="cta-badges">
        <span class="cta-badge">Licensed &amp; Insured</span>
        <span class="cta-badge">Same-Day Available</span>
        <span class="cta-badge">Humane Methods</span>
      </div>
    </div>
  </div>
</section>

${post.faqs && post.faqs.length ? `
<section class="county-content" style="background:#f8fafc;">
  <div class="container">
    <h2>Frequently Asked Questions</h2>
    <div style="display:flex;flex-direction:column;gap:12px;margin-top:16px;max-width:780px;">
      ${post.faqs.map((f, i) => `
        <details style="border:1px solid #e5e7eb;border-radius:10px;background:#fff;overflow:hidden;"${i === 0 ? ' open' : ''}>
          <summary style="padding:16px 20px;font-weight:600;cursor:pointer;font-size:0.98rem;list-style:none;display:flex;justify-content:space-between;align-items:center;">
            ${f.q}
            <span style="font-size:1.2rem;flex-shrink:0;margin-left:12px;">+</span>
          </summary>
          <div style="padding:0 20px 16px;color:#374151;line-height:1.7;font-size:0.94rem;border-top:1px solid #f3f4f6;">${f.a}</div>
        </details>
      `).join('')}
    </div>
  </div>
</section>
` : ''}

${relatedPosts.length ? `
<section class="counties-section">
  <div class="container">
    <div class="section-header">
      <h2>More From the Blog</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
      ${relatedPosts.map(rp => `
        <a href="/blog/${rp.slug}/" style="text-decoration:none;color:inherit;border:1px solid #e5e7eb;border-radius:12px;padding:20px;background:#fff;display:block;">
          <span style="background:var(--green-light);color:var(--green-dark);padding:3px 10px;border-radius:6px;font-size:0.75rem;font-weight:600;">${rp.category}</span>
          <h3 style="font-size:1.1rem;margin:12px 0 8px;color:#0f172a;line-height:1.35;">${rp.title}</h3>
          <p style="color:#64748b;font-size:0.9rem;margin:0;line-height:1.55;">${rp.excerpt}</p>
        </a>
      `).join('')}
    </div>
  </div>
</section>
` : ''}

` }) %>
